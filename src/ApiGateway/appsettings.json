{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "admin-route": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "api/admin/{**catch-all}"
        }
      },
      "ticket-route": {
        "ClusterId": "ticket-cluster",
        "RateLimiterPolicy": "booking-limit",
        "Match": {
          "Path": "api/tickets/{**catch-all}"
        }
      },
      "health-route": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "health"
        }
      },
      "auth-route": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "api/auth/{**catch-all}"
        }
      },
      "posters-route": {
        "ClusterId": "ticket-cluster",
        "Match": { "Path": "posters/{**catch-all}" }
      },
      "scalar-route": {
        "ClusterId": "ticket-cluster",
        "Match": { "Path": "scalar/{**catch-all}" }
      },
      "openapi-route": {
        "ClusterId": "ticket-cluster",
        "Match": { "Path": "openapi/{**catch-all}" }
      },
      "payment-webhook-route": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "api/tickets/webhook/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ticket-cluster": {
        "Destinations": {
          "service-a": {
            "Address": "http://service-a:5018"
          }
        }
      }
    }
  }
}
